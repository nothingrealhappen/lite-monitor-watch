{
  "name": "lite-monitor-watch",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "run-p dev:*",
    "dev:web": "remix vite:dev --host 0.0.0.0 --port 35001",
    "dev:poller": "tsx scripts/poller.ts",
    "build": "remix vite:build",
    "start": "sh ./scripts/start.sh",
    "start:web": "remix-serve build/server/index.js --port 35001",
    "db:poll": "tsx scripts/poller.ts --once",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@remix-run/node": "^2.17.4",
    "@remix-run/react": "^2.17.4",
    "@remix-run/serve": "^2.17.4",
    "cheerio": "^1.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.17.4",
    "@types/node": "^24.9.1",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
